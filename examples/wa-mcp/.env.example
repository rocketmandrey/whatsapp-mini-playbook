# Copy to .env (gitignored). On a server: chmod 600 .env
# The bridge auto-loads ./.env; the MCP loads it too (WA_ENV_PATH to override).

# ── Bridge (bridge.js) ──
QR_PORT=8795                 # public QR/status page — CLOSE with firewall after linking
ADMIN_PORT=8799              # control API (/me /chats /history /send) — keep on 127.0.0.1
BRIDGE_TOKEN=                # secret gating the control API (>=16 chars, recommended)
ALL_DB_PATH=./all_chats.db   # archive of ALL chats (groups + DMs)
TARGET_GROUP_NAME=           # OPTIONAL: also mirror ONE exact group name into whatsapp.db; blank = off

# ── MCP over the archive (lib.mjs / mcp-server.mjs / http-server.mjs) ──
WA_DB_PATH=./all_chats.db    # which DB the MCP reads
WA_DRAFTS_DB_PATH=./drafts.db
WA_BRIDGE_URL=http://127.0.0.1:8799   # where the MCP reaches the bridge control API
WA_MCP_PORT=8796             # HTTP MCP port (bind localhost; expose only via SSH tunnel / TLS)
WA_MCP_SECRET=               # secret-in-URL for the HTTP MCP (>=16 chars). Path = /<secret>/mcp

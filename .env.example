# ═══════════════════════════════════════════════════════════════════════
#  WhatsApp Mini Playbook — переменные окружения (ШАБЛОН)
#  Скопируй в .env (он в .gitignore), на сервере: chmod 600 .env
#  Реальные значения НИКОГДА не коммить и не печатать в чат.
#  Внешних ключей нет — оба секрета агент генерит сам (openssl rand -hex 24).
# ═══════════════════════════════════════════════════════════════════════

WA_DOMAIN=wa-mcp.example.com  # поддомен под WhatsApp MCP (A-запись на IP сервера)
BRIDGE_TOKEN=                 # секрет control-API моста: openssl rand -hex 24
WA_MCP_SECRET=                # секрет-в-URL для HTTP MCP: openssl rand -hex 24

SERVER_HOST=your-server.example.com   # домен/IP VPS (для SSH и nginx)
# SSH-доступ держи в ssh-config/ключах, НЕ здесь.
# Полный набор переменных моста и MCP — examples/wa-mcp/.env.example
